# ── App (build-time) ─────────────────────────────────────────
# The backend URL baked into the Vue build.
# In dev: leave empty (Vite proxy handles /api/*).
# In production: set to your actual backend URL.
VITE_API_BASE_URL=

# Cloudflare Turnstile site key for the login page.
# Use the Cloudflare test key only for local development/testing.
VITE_TURNSTILE_SITE_KEY=
